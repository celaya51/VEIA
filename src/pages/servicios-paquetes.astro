---
import Base from '../layouts/Base.astro';

const mensuales = [
  {
    nombre: 'Presencia', precio: '1,200', destacado: false, nota: 'Para que te encuentren y te vean activo.',
    items: ['Google Maps creado/optimizado', 'Respuesta a reseñas', 'Mantenemos vivo tu sitio', '4 publicaciones/mes (1 red)', 'Diseño de las piezas'],
    no: ['Pauta, video, WhatsApp Business'],
    wa: 'Me%20interesa%20el%20plan%20Presencia',
  },
  {
    nombre: 'Activo', precio: '2,800', destacado: true, nota: 'Activo en redes y atendiendo clientes.',
    items: ['Todo lo de Presencia', '8 publicaciones/mes (2 redes)', 'WhatsApp Business configurado', 'Respondemos mensajes/comentarios', '1 reel/video corto al mes', 'Reporte simple mensual'],
    no: [],
    wa: 'Me%20interesa%20el%20plan%20Activo',
  },
  {
    nombre: 'Impulso', precio: '4,500', destacado: false, nota: 'Para vender más con anuncios.',
    items: ['Todo lo de Activo', '12 publicaciones/mes', 'Gestión de pauta (Meta)*', 'Copywriting de anuncios', 'SEO local básico'],
    no: [],
    wa: 'Me%20interesa%20el%20plan%20Impulso',
  },
];
---
<Base current="precios" title="Precios y paquetes · VEIA" description="Paquetes de marketing, sitios web Express y soluciones de TI a la medida. Precios en pesos, IVA incluido.">

  <section class="page-hero anim-grad">
    <div class="aurora"><span class="b1"></span><span class="b2"></span><span class="b3"></span></div>
    <div class="container">
      <span class="hero-eyebrow">Precios</span>
      <h1 class="h2" style="color:#fff">Planes claros, en pesos y con IVA incluido</h1>
      <p class="lead" style="color:rgba(255,255,255,.95)">Empieza pequeño y crece a tu ritmo. Sin contratos enredados ni letras chiquitas.</p>
    </div>
  </section>

  <!-- SITIO EXPRESS -->
  <section class="section bg-cream">
    <div class="container">
      <span class="eyebrow">Lo más pedido</span>
      <h2 class="h2" style="margin-bottom:6px">Sitio Express</h2>
      <div class="grid grid-2 mt">
        <article class="plan plan--destacado">
          <span class="plan-badge">Pago único</span>
          <h3 class="plan-nombre">Tu sitio en una llamada</h3>
          <div class="plan-precio">$3,500 <small>una sola vez</small></div>
          <ul class="plan-lista">
            <li>1 videollamada o sesión presencial de hasta 3 horas</li>
            <li>Lo armamos juntos, paso a paso (aprendes a usarlo)</li>
            <li>Queda en tu propia cuenta</li>
            <li>Listo el mismo día</li>
            <li class="no">Hosting/dominio: lo contratas tú o lo incluimos</li>
            <li class="no">Sin cambios posteriores (se entrega tal cual)</li>
          </ul>
          <a href="https://wa.me/525659898908?text=Quiero%20el%20Sitio%20Express" target="_blank" rel="noopener" class="btn btn-block">Lo quiero</a>
        </article>
        <article class="card">
          <h3 style="margin-bottom:14px">Complementos (aparte)</h3>
          <table class="pricetable">
            <tr><td>Administración mensual <span class="note">(mantenimiento, respaldos, 1–2 cambios/mes)</span></td><td class="num">$900/mes</td></tr>
            <tr><td>Branding básico <span class="note">(logo + colores + tipografías)</span></td><td class="num">$2,500</td></tr>
            <tr><td>Capacitación extra <span class="note">(sesión adicional hasta 1.5 h)</span></td><td class="num">$700</td></tr>
          </table>
          <p class="note" style="margin-top:14px;color:var(--muted);font-size:.85rem">¿Quieres que además lo mantengamos vivo y crezca? Mira los planes mensuales 👇</p>
        </article>
      </div>
    </div>
  </section>

  <!-- PLANES MENSUALES -->
  <section class="section bg-cream2">
    <div class="container center"><span class="eyebrow">Planes mensuales</span><h2 class="h2">Para que tu negocio se vea activo y crezca</h2></div>
    <div class="container">
      <div class="grid grid-3 mt-lg">
        {mensuales.map((p) => (
          <article class:list={["plan", p.destacado && "plan--destacado"]}>
            {p.destacado && <span class="plan-badge">El más elegido</span>}
            <h3 class="plan-nombre">{p.nombre}</h3>
            <div class="plan-precio">${p.precio} <small>/mes</small></div>
            <p class="plan-nota">{p.nota}</p>
            <ul class="plan-lista">
              {p.items.map((it) => <li>{it}</li>)}
              {p.no.map((it) => <li class="no">{it}</li>)}
            </ul>
            <a href={`https://wa.me/525659898908?text=${p.wa}`} target="_blank" rel="noopener" class:list={["btn", "btn-block", !p.destacado && "btn--ghost"]}>Elegir</a>
          </article>
        ))}
      </div>
      <p class="note-line">*La inversión en anuncios (lo que se le paga a Meta/Google) la pones tú aparte, desde ~$1,500/mes. Nosotros la administramos.</p>
      <p class="note-line">¿Negocio más grande? Tenemos planes a la medida — <a href="/contacto.html">cotiza aquí</a>.</p>
    </div>
  </section>

  <!-- SOLUCIONES IT -->
  <section class="section bg-cream">
    <div class="container center"><span class="eyebrow">VEIA Soluciones</span><h2 class="h2">Tecnología a la medida</h2></div>
    <div class="container">
      <div class="grid grid-2 mt-lg">
        <article class="card">
          <h3 style="margin-bottom:14px">💻 Software a la medida</h3>
          <table class="pricetable">
            <tr><th>Solución</th><th style="text-align:right">Desde</th></tr>
            <tr><td>Herramienta sencilla (1 flujo) <span class="note">~1 semana</span></td><td class="num">$8,000</td></tr>
            <tr><td>App web (varios módulos) <span class="note">~2–4 semanas</span></td><td class="num">$20,000</td></tr>
            <tr><td>Solución completa (mini-ERP) <span class="note">~6–10 semanas</span></td><td class="num">$45,000</td></tr>
            <tr><td>Soporte/hosting mensual</td><td class="num">desde $900/mes</td></tr>
          </table>
        </article>
        <article class="card">
          <h3 style="margin-bottom:14px">🖧 Infraestructura y redes</h3>
          <table class="pricetable">
            <tr><th>Servicio</th><th style="text-align:right">Desde</th></tr>
            <tr><td>Estudio + propuesta <span class="note">~1 sem</span></td><td class="num">$3,500</td></tr>
            <tr><td>Instalación (mano de obra) <span class="note">por cotización</span></td><td class="num">$8,000</td></tr>
            <tr><td>Soporte de TI (iguala mensual)</td><td class="num">desde $3,000/mes</td></tr>
            <tr><td>Hardware (router, APs, NAS…)</td><td class="num">aparte</td></tr>
          </table>
        </article>
      </div>
    </div>
  </section>

  <!-- OTROS SERVICIOS -->
  <section class="section bg-cream2">
    <div class="container center"><span class="eyebrow">Proyectos únicos</span><h2 class="h2">Otros servicios (pago único)</h2></div>
    <div class="container" style="max-width:680px">
      <table class="pricetable mt-lg">
        <tr><td>Sitio web a la medida <span class="note">~1–4 semanas</span></td><td class="num">desde $8,000</td></tr>
        <tr><td>Branding / identidad <span class="note">~1 semana</span></td><td class="num">desde $3,500</td></tr>
        <tr><td>Sesión de fotografía</td><td class="num">desde $1,500</td></tr>
        <tr><td>Producción de video / comercial</td><td class="num">cotización</td></tr>
      </table>
      <p class="note-line center">Todos los precios en pesos mexicanos (MXN) con IVA incluido. Son de referencia y se ajustan según tu proyecto.</p>
      <div class="center" style="margin-top:22px"><a href="https://wa.me/525659898908?text=Quiero%20una%20cotizaci%C3%B3n" target="_blank" rel="noopener" class="btn btn--lg">Cotiza tu proyecto</a></div>
    </div>
  </section>

</Base>

<style>
  .plan {
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius-lg);
    padding: 34px 30px; display: flex; flex-direction: column; position: relative;
    box-shadow: var(--shadow); transition: transform var(--t), box-shadow var(--t);
  }
  .plan:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
  .plan--destacado { border: 2px solid var(--orange); box-shadow: 0 18px 45px rgba(252,119,62,.24); }
  .plan-badge {
    position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
    background: var(--grad-warm); color: #fff; font-family: 'Poppins', sans-serif; font-weight: 600;
    font-size: .74rem; letter-spacing: .5px; padding: 6px 16px; border-radius: 100px; white-space: nowrap;
  }
  .plan-nombre { font-size: 1.25rem; }
  .plan-precio { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 2rem; margin: 6px 0 2px; }
  .plan-precio small { font-size: .85rem; font-weight: 600; color: var(--muted); }
  .plan-nota { color: var(--muted); font-size: .9rem; margin-bottom: 16px; }
  .plan-lista { list-style: none; display: grid; gap: 10px; margin-bottom: 24px; flex: 1; }
  .plan-lista li { position: relative; padding-left: 26px; font-size: .94rem; }
  .plan-lista li::before { content: "✓"; position: absolute; left: 0; color: var(--orange); font-weight: 800; }
  .plan-lista li.no { color: var(--muted); }
  .plan-lista li.no::before { content: "–"; color: var(--muted); }
  .note-line { font-size: .85rem; color: var(--muted); margin-top: 14px; }
  .note-line a { color: var(--orange-d); font-weight: 600; }
</style>
